{
  "cli": {
    "version": ">=13.4.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "autoIncrement": true,
      "channel": "development",
      "developmentClient": true,
      "node": "22.17.1",
      "env": {
        "NODE_AUTH_TOKEN": "$NODE_AUTH_TOKEN",
        "EXPO_PUBLIC_APP_ENV": "development"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "channel": "production",
      "node": "22.17.1",
      "env": {
        "NODE_AUTH_TOKEN": "$NODE_AUTH_TOKEN",
        "EXPO_PUBLIC_APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID"
      },
      "android": {
        "track": "production"
      }
    }
  }
}
