{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "scripts-src/**/*.ts",
    "tests/**/*.ts",
    "tsup.docs.config.ts",
    "vitest.config.ts",
    "eslint.docs.config.mjs"
  ]
}
